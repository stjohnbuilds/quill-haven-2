{
  "manifest_version": 3,
  "name": "Quill Haven",
  "version": "2.3.16",
  "description": "The Quill Haven shell — one bar, dock and settings on every page — plus the lockdown that keeps the laptop on your writing apps.",
  "permissions": ["storage", "webNavigation", "tabs", "idle"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["apps.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    { "resources": ["shell.css"], "matches": ["http://*/*", "https://*/*"] }
  ]
}
